# Staged build-context artifacts (copied from canonical repo locations by
# containers/prepare-context.mjs — never commit duplicates of binaries/CA).
containers/corporate-ca.pem
agt-opencode-0.1.0.tgz
containers/agt-opencode-0.1.0.tgz

# Generated decoy tree (regenerated per run by containers/gen-decoys.mjs): fake
# secrets, the canary manifest, AND the benign fixture files. All FAKE; each
# secret carries a fresh CANARY-AGT-<uuid> so a transcript/egress capture maps
# to the live run. Regenerate before reproduce. (project/.env.example stays
# tracked as the documented benign-read target — regenerated byte-identically.)
containers/decoys/.ssh/id_rsa
containers/decoys/.aws/credentials
containers/decoys/project/
containers/decoys/canaries.json

# Runtime credentials — NEVER committed. Injected via -e / compose ${VAR} only.
.env
*.env.local
containers/.env

# Live/raw results (committed deliberately later; ignore scratch).
results/raw/scratch/

# Non-deterministic run artifacts (wall-clock/timestamps) — regenerable
results/latency.json
results/raw/

# Live-track raw output: transcripts (canary/decoy/cred-bearing), squid logs,
# per-run category JSONs, and contaminated/quarantined data. NEVER committed
# raw — only scrubbed summary numbers are folded into docs/BENCHMARK.md §8.
results/live/
